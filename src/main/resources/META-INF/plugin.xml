<idea-plugin>
    <id>com.github.mark.psx-plugin</id>
    <name>PSX MIPS and PsyQ Support</name>
    <vendor>Mark</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.clion</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="MIPS Assembly" implementationClass="com.github.mark.psxplugin.MipsFileType" fieldName="INSTANCE" language="MIPS" extensions="asm;s"/>
        <lang.syntaxHighlighterFactory language="MIPS" implementationClass="com.github.mark.psxplugin.MipsSyntaxHighlighterFactory"/>
        <lang.commenter language="MIPS" implementationClass="com.github.mark.psxplugin.MipsCommenter"/>
        <completion.contributor language="any" implementationClass="com.github.mark.psxplugin.PsyQCompletionContributor"/>
        <lang.documentationProvider language="MIPS" implementationClass="com.github.mark.psxplugin.MipsDocumentationProvider"/>
        <lang.documentationProvider language="ObjectiveC" implementationClass="com.github.mark.psxplugin.PsyQDocumentationProvider"/>

        <liveTemplateContext contextId="PSYQ" implementation="com.github.mark.psxplugin.PsyQLiveTemplateContext"/>
        <liveTemplateContext contextId="MIPS" implementation="com.github.mark.psxplugin.MipsLiveTemplateContext"/>
        <defaultLiveTemplates file="liveTemplates/PsyQ.xml"/>
        <defaultLiveTemplates file="liveTemplates/MIPS.xml"/>
    </extensions>
</idea-plugin>
