<idea-plugin>
    <id>com.github.mark.psx-plugin</id>
    <name>PSX MIPS and PsyQ Support</name>
    <vendor>Mark</vendor>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.modules.clion</depends>
    <depends>com.intellij.modules.lang</depends>

    <extensions defaultExtensionNs="com.intellij">
        <fileType name="MIPS Assembly" implementationClass="com.github.mark.psxplugin.MipsFileType" fieldName="INSTANCE" language="PSX_MIPS" extensions="asm;s"/>
        <lang.syntaxHighlighterFactory language="PSX_MIPS" implementationClass="com.github.mark.psxplugin.MipsSyntaxHighlighterFactory"/>
        <lang.commenter language="PSX_MIPS" implementationClass="com.github.mark.psxplugin.MipsCommenter"/>
        <lang.parserDefinition language="PSX_MIPS" implementationClass="com.github.mark.psxplugin.MipsParserDefinition"/>
        <completion.contributor language="any" implementationClass="com.github.mark.psxplugin.PsyQCompletionContributor"/>
        <completion.contributor language="PSX_MIPS" implementationClass="com.github.mark.psxplugin.MipsCompletionContributor"/>
        
        <!-- Registration for Mips -->
        <lang.documentationProvider language="PSX_MIPS" implementationClass="com.github.mark.psxplugin.MipsDocumentationProvider"/>
        <annotator language="PSX_MIPS" implementationClass="com.github.mark.psxplugin.MipsAnnotator"/>
        
        <!-- Cross-registration for C/C++ -->
        <lang.documentationProvider language="ObjectiveC" implementationClass="com.github.mark.psxplugin.PsyQDocumentationProvider"/>
        <lang.documentationProvider language="C" implementationClass="com.github.mark.psxplugin.PsyQDocumentationProvider"/>
        <lang.documentationProvider language="C++" implementationClass="com.github.mark.psxplugin.PsyQDocumentationProvider"/>
        
        <liveTemplateContext contextId="PSYQ" implementation="com.github.mark.psxplugin.PsyQLiveTemplateContext"/>
        <liveTemplateContext contextId="MIPS" implementation="com.github.mark.psxplugin.MipsLiveTemplateContext"/>
        <defaultLiveTemplates file="liveTemplates/PsyQ.xml"/>
        <defaultLiveTemplates file="liveTemplates/MIPS.xml"/>
        <directoryProjectGenerator implementation="com.github.mark.psxplugin.PsxProjectGenerator"/>
    </extensions>

    <actions>
        <action id="com.github.mark.psxplugin.CreateMipsAsmAction"
                class="com.github.mark.psxplugin.CreateMipsAsmAction">
            <add-to-group group-id="NewGroup" anchor="after" relative-to-action="NewFile"/>
        </action>
    </actions>
</idea-plugin>
